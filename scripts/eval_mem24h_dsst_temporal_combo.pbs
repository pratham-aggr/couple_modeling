#!/bin/bash
#PBS -N eval_combo
#PBS -A ucsd0044
#PBS -q nvgpu
#PBS -l select=1:ncpus=16:ngpus=1:mem=128GB:gpu_type=a100
#PBS -l walltime=01:00:00
#PBS -o /glade/u/home/praggarwal/couple/eval_mem24h_dsst_temporal_combo.log
#PBS -e /glade/u/home/praggarwal/couple/eval_mem24h_dsst_temporal_combo.err
#PBS -j oe

COUPLE_DIR=/glade/u/home/praggarwal/couple
ZARR_GLOB="/glade/derecho/scratch/wchapman/b_credit_runs/b.e21.CREDIT_climate_branch_1980_????_zmdata_ERA5scaled_zmdata_Qtot.zarr"

set -euo pipefail
echo "PBS job started: $(date), node=$(hostname), jobid=$PBS_JOBID"

module load conda
conda activate /glade/work/praggarwal/conda-envs/atm

cd ${COUPLE_DIR}

# Eval-only: score the combo (augment+dropout) best_model.pt on the locked 2013-2014 test set.
echo "Eval-only test R2 for combo run at $(date)"
python -u train_unet.py \
    --zarr_glob     "${ZARR_GLOB}" \
    --out_dir       ${COUPLE_DIR}/output_unet_mem24h_dsst_temporal_combo \
    --subsample     1.0 \
    --memory \
    --batch         8 \
    --base          64 \
    --dsst_dt \
    --augment \
    --dropout       0.1 \
    --split_mode    temporal \
    --eval_test \
    --wandb_project couple-unet

echo "Done at $(date)"
